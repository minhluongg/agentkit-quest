# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
dist/
bin/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# package manager
# NOTE: package-lock.json is intentionally NOT ignored — Vercel needs the lockfile
# for reproducible builds.
yarn.lock
pnpm-lock.yaml

# semantic-release
.nyc_output

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# flutter
.dart_tool
build
GoogleService-Info.plist

repomix-output.xml
.serena/cache
plans/**/*
!plans/templates/*
screenshots/*
docs/screenshots/*
logs.txt
test-ck
__pycache__

# CK meta commands
prompt.md
ck.md

# Generated runtime layout for release/install smoke tests
/.claude/
# But track repo-level rules that Claude Code reads
!/.claude/rules/

# Local-only state inside tracked claude source
claude/agent-memory/
claude/hooks/.logs/
claude/session-state/latest.md
claude/session-state/archive/
claude/settings.bak.json
claude/skills/ai-multimodal/assets/demo-*.claude/session-state/*.tmp

# Gemini CLI settings (symlink to staged .claude/.mcp.json)
.gemini/settings.json
# Showoff/marketing assets (images, showcases)
assets/
# Exception: use-mcp ships a persistent tool catalog at assets/tools.json
!claude/skills/use-mcp/assets/
!claude/skills/use-mcp/assets/**

# External repos for study/reference
external/

# Git worktrees (local development only)
worktrees/

# ---------------------------------------------------------------------------
# agentkit.quest (Next.js app)
# ---------------------------------------------------------------------------

# Vendored copy of the private AgentKit Engineer kit. Reference only — it is the
# SOURCE for `npm run catalog:build`, never a build-time dependency. It must not
# land in a public repo.
/claudekit-engineer/
/release-manifest.json

# fumadocs-mdx codegen output
/.source/

# The link-asset repo. It is its own git repository and is published separately to
# GitHub — it must NOT be committed inside the site repo.
/claude-code-hooks/


.vercel
.env*

# Vendored AgentKit Engineer kit (built via `ak kit init --build-only`). Not ours to commit.
/agentkit-engineer/
